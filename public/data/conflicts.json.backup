    "objectivesMet": true,
    "computed": {
      "durationYears": 1,
      "durationDays": 365,
      "costPerDay": 1095890,
      "costPerUSdeath": 17391304,
      "costPerCivilianDeath": 800000,
      "totalDeaths": 523,
      "civilianToMilitaryRatio": 21.7,
      "deathsPerYear": 23,
      "civilianDeathsPerYear": 500
