  {
    "id": "afghanistan",
    "name": "War in Afghanistan",
    "shortName": "Afghanistan",
    "era": "War on Terror",
    "type": "war",
    "startYear": 2001,
    "endYear": 2021,
    "region": "Central Asia",
    "countries": [
      "Afghanistan",
