  {
    "id": "isis-iraq-syria",
    "name": "War Against ISIS",
    "shortName": "Anti-ISIS",
    "era": "War on Terror",
    "type": "war",
    "startYear": 2014,
    "endYear": null,
    "region": "Middle East",
