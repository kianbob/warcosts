    "id": "world-war-i",
    "name": "World War I",
    "shortName": "World War I",
    "era": "World Wars",
    "type": "war",
    "startYear": 1917,
    "endYear": 1918,
    "region": "Europe",
    "countries": [
      "Germany",
      "Austria-Hungary",
